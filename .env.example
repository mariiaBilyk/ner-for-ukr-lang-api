# ═══════════════════════════════════════════════════════════════════
# .env.example — copy to .env and fill in your values
#
# THIS FILE is the single source of truth for all defaults.
# config.py, docker-compose.yml, and CI scripts all read from here.
# Change a value here; it propagates everywhere.
# ═══════════════════════════════════════════════════════════════════

# ── Docker Hub (used by deploy-azure.sh) ─────────────────────────
DOCKERHUB_USERNAME=

# ── Inference ────────────────────────────────────────────────────
INFERENCE_BACKEND=ollama

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M   # <── only place this default lives

# ── Prompt ───────────────────────────────────────────────────────
PROMPT_NAME=ner
PROMPT_VERSION=          # empty = latest

# ── NER Agent ────────────────────────────────────────────────────
EXTRACTION_STRATEGY=simple    # simple | self_critique
NER_AGENT_MAX_ATTEMPTS=3
